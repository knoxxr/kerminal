# Copy to android/key.properties and fill in your release keystore details.
# This file (key.properties) and the .jks keystore are gitignored — never commit
# them. In CI, generate key.properties from secrets instead.
#
# Create a keystore with:
#   keytool -genkey -v -keystore kerminal-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias kerminal
storePassword=changeit
keyPassword=changeit
keyAlias=kerminal
storeFile=/absolute/path/to/kerminal-release.jks
